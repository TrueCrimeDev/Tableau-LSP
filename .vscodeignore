# Exclude everything by default to prevent accidental leaks.
**/*

# Marketplace metadata
!package.json
!README.md
!CHANGELOG.md
!LICENSE

# Runtime assets used by the extension
!language-configuration.json
!twb-language-configuration.json
!syntaxes/**
!snippets/**
!images/tableau-icon.png
!images/tableau2.png
!images/tableau2.svg
!config/Preferences.tps

# Bundled extension entry points
!out/extension.js
!out/server.js

!media/parsingGuideSidebar.js

# Formatting Panel webview assets
!media/formattingPanel.js
!media/formattingPanel.css

# Keep source maps out of the package
out/**/*.map
