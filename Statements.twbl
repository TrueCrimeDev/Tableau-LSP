// Check Initiative and District Office
IF  
(
  CONTAINS([!Initiative2], "Agriculture") OR 
  CONTAINS([!Initiative2], "Building Services") OR 
  CONTAINS([!Initiative2], "Care") OR 
  CONTAINS([!Initiative2], "Food Services") OR 
  CONTAINS([!Initiative2], "Government Contract") OR 
  CONTAINS([!Initiative2], "Residential Construction") OR 
  CONTAINS([!Initiative2], "Warehouse")
) 
AND 
(
  [Investigating DO] = "Chicago IL District Office" OR 
  [Investigating DO] = "Columbus OH District Office" OR 
  [Investigating DO] = "Des Moines IA District Office" OR 
  [Investigating DO] = "Detroit MI District Office" OR 
  [Investigating DO] = "Grand Rapids MI District Office" OR 
  [Investigating DO] = "Indianapolis IN District Office" OR 
  [Investigating DO] = "Kansas City KS District Office" OR 
  [Investigating DO] = "Minneapolis MN District Office" OR 
  [Investigating DO] = "St. Louis MO District Office"
)
THEN 
  TRUE 
ELSE 
  FALSE 
END


// Check Initiative Presence and Contains District Office
IF  
(
  CONTAINS([!Initiative2], "Agriculture") OR 
  CONTAINS([!Initiative2], "Building Services") OR 
  CONTAINS([!Initiative2], "Care") OR 
  CONTAINS([!Initiative2], "Food Services") OR 
  CONTAINS([!Initiative2], "Government Contract") OR 
  CONTAINS([!Initiative2], "Residential Construction") OR 
  CONTAINS([!Initiative2], "Warehouse")
) 
AND 
(
  CONTAINS([Investigating DO], "Chicago IL District Office") OR 
  CONTAINS([Investigating DO], "Columbus OH District Office") OR 
  CONTAINS([Investigating DO], "Des Moines IA District Office") OR 
  CONTAINS([Investigating DO], "Detroit MI District Office") OR 
  CONTAINS([Investigating DO], "Grand Rapids MI District Office") OR 
  CONTAINS([Investigating DO], "Indianapolis IN District Office") OR 
  CONTAINS([Investigating DO], "Kansas City KS District Office") OR 
  CONTAINS([Investigating DO], "Minneapolis MN District Office") OR 
  CONTAINS([Investigating DO], "St. Louis MO District Office")
)
AND 
(
  CONTAINS([Strat Init Fy], "2025")
)
THEN 
  TRUE 
ELSE 
  FALSE 
END


// !DO_Ini
CASE [SPONSORING_DO]
WHEN "Chicago IL District Office" THEN "CH"
WHEN "Columbus OH District Office" THEN "CO"
WHEN "Des Moines IA District Office" THEN "DM"
WHEN "Detroit MI District Office" THEN "DT"
WHEN "Grand Rapids MI District Office" THEN "GR"
WHEN "Indianapolis IN District Office" THEN "IN"
WHEN "Kansas City KS District Office" THEN "KC"
WHEN "Minneapolis MN District Office" THEN "MN"
WHEN "St. Louis MO District Office" THEN "SL"
ELSE NULL
END

// !DO_Ini
CASE [DISTRICT]
WHEN "Chicago IL District Office" THEN "CH"
WHEN "Columbus OH District Office" THEN "CO"
