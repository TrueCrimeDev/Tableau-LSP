WHEN "Detroit MI District Office" THEN "DT"
WHEN "Grand Rapids MI District Office" THEN "GR"
WHEN "Indianapolis IN District Office" THEN "IN"
WHEN "Kansas City KS District Office" THEN "KC"
WHEN "Minneapolis MN District Office" THEN "MN"
WHEN "St. Louis MO District Office" THEN "SL"
ELSE NULL
END


// !DO_Name_Rest
IF ISNULL([COMPLAINT_DISTRICT]) THEN
    NULL
ELSEIF RIGHT([COMPLAINT_DISTRICT], LEN(" District Office")) = " District Office" THEN
    LEFT([COMPLAINT_DISTRICT], LEN([COMPLAINT_DISTRICT]) - LEN(" District Office"))
ELSE
    [COMPLAINT_DISTRICT]
END


