// DO_Name_Clean
IF ISNULL([INVESTIGATING_DO]) THEN
    NULL
ELSEIF CONTAINS([INVESTIGATING_DO], "Program Operations Office") THEN
    NULL
ELSEIF RIGHT([INVESTIGATING_DO], LEN(" District Office")) = " District Office" THEN
    LEFT([INVESTIGATING_DO], LEN([INVESTIGATING_DO]) - LEN(" District Office"))
ELSE
    [INVESTIGATING_DO]
END


// !RO_Ini - The ROs made into initials
IF [INVESTIGATING_RO] = "Northeast Regional Office" THEN "NE"
ELSEIF [INVESTIGATING_RO] = "Southeast Regional Office" THEN "SE"
ELSEIF [INVESTIGATING_RO] = "Midwest Regional Office" THEN "MW"
ELSEIF [INVESTIGATING_RO] = "Southwest Regional Office" THEN "SW"
ELSEIF [INVESTIGATING_RO] = "Western Regional Office" THEN "WE"
ELSE [INVESTIGATING_RO]
END



